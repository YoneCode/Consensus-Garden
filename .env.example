# Copy this file to .env (which is gitignored) and fill in your own values.

# Sponsor / deployer private key for GenLayer Testnet Bradbury.
# Pays for gasless mints and contract deploys. Keep this secret.
DEPLOYER_PRIVATE_KEY=

# GenLayer Testnet Bradbury
GENLAYER_RPC=https://rpc-bradbury.genlayer.com
GENLAYER_CHAIN_ID=4221

# Mint phase: unix seconds when mint opens to everyone.
# Set to 1 for always-open; set to a future timestamp for a builders-only window first.
PHASE2_AT=1

# Optional: HTTP port for the backend (default 3000)
# PORT=3000
